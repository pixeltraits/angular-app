    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/localize": "^21.2.0",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^5.4.0",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
